              "mode": "raw",
              "raw": "{\n  \"clientId\": \"{{clientId}}\",\n  \"serviceId\": \"{{serviceId}}\",\n  \"title\": \"Marketplace Backend Delivery\",\n  \"description\": \"Complete backend implementation\",\n  \"amount\": 1200,\n  \"currency\": \"USD\",\n  \"deliveryDate\": \"2026-04-20T12:00:00.000Z\",\n  \"requirements\": \"Repo access and docs\",\n  \"notes\": \"Priority\",\n  \"attachmentUrls\": [],\n  \"phases\": [\n    { \"title\": \"Phase 1\", \"percentage\": 50, \"deliveryDays\": 3 },\n    { \"title\": \"Phase 2\", \"percentage\": 50, \"deliveryDays\": 4 }\n  ]\n}"
